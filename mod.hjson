#the mod name as displayed in-game
displayName: PatchEditor

#the internal name of your mod
name: "patch-editor"

#your name
author: "minRi2"

#the fully qualified main class of the mod
main: "MinRi2.PatchEditor.Main"

#the mod description as seen in the mod dialog
description: "Provide an in-game GUI for DataPatcher."

#the mod version
version: 1.9.0

#the minimum game build required to run this mod
minGameVersion: 156

#this is a java mod
java: true

hidden: true
